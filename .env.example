# Supabase project URL — copy from `supabase status` (Project URL) or your hosted project settings.
VITE_SUPABASE_URL=http://127.0.0.1:54321

# Supabase anonymous (publishable) key — safe to expose in client code.
# Supabase CLI v2 emits a project-specific `sb_publishable_*` key (not a JWT).
# Find it in `supabase status` under "Publishable", or in your hosted project
# settings under API → Project API Keys → anon / public.
VITE_SUPABASE_ANON_KEY=
